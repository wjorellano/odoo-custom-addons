<?xml version="1.0" encoding="utf-8"?>
<templates>
    <t t-name="sale_kit_report.SaleKitBreakdownTable">
        <div class="o_action_manager o_mrp_bom_report h-100 bg-view">
            <div class="o_content p-4 overflow-auto">
                <h3 class="mb-4 text-primary">Sale Order Kit Breakdown</h3>

                <table class="table table-borderless o_list_table">
                    <thead class="border-bottom">
                        <tr>
                            <th>Product</th>
                            <th class="text-end">Quantity</th>
                            <th class="text-end">UoM</th>
                            <th class="text-end">Price</th>
                            <th class="text-end">Total</th>
                        </tr>
                    </thead>
                    <tbody>
                        <t t-foreach="visibleLines" t-as="line" t-key="line.id">
                            <t t-set="isLine" t-value="line.type === 'line'"/>

                            <tr class="border-bottom-0">
                                <td t-att-style="'padding-left: ' + (line.indent * 30 + 10) + 'px;'">
                                    <div class="d-flex align-items-center">
                                        <span t-if="line.has_bom"
                                              class="me-2"
                                              style="cursor: pointer; width: 15px; display: inline-block;"
                                              t-on-click="() => this.toggleExpand(line.id)">
                                            <i t-att-class="state.expandedLines[line.id] ? 'fa fa-fw fa-caret-down' : 'fa fa-fw fa-caret-right'"/>
                                        </span>
                                        <span t-else="" style="width: 23px; display: inline-block;"/>

                                        <span t-att-class="isLine ? 'text-info fw-bold' : 'text-info'">
                                            <t t-esc="line.product_name"/>
                                        </span>

                                        <span t-if="line.has_bom" class="fa fa-cogs ms-2 text-muted" title="Kit/BoM"/>
                                    </div>
                                </td>

                                <td class="text-end"><t t-esc="line.quantity.toFixed(2)"/></td>
                                <td class="text-end"><t t-esc="line.uom"/></td>
                                <td class="text-end">$ <t t-esc="line.unit_price.toFixed(2)"/></td>
                                <td class="text-end">$ <t t-esc="line.amount_total.toFixed(2)"/></td>
                            </tr>
                        </t>
                    </tbody>
                </table>

                <div class="row justify-content-end mt-4 mb-4 pe-2">
                    <div class="col-12 col-sm-6 col-md-5 col-lg-4">
                        <table class="table table-sm table-borderless mb-0">
                            <tr>
                                <td class="text-end fw-bold text-muted">Untaxed Amount:</td>
                                <td class="text-end" style="width: 120px;">$ <t t-esc="state.totals.untaxed.toFixed(2)"/></td>
                            </tr>
                            <tr>
                                <td class="text-end fw-bold text-muted">Taxes:</td>
                                <td class="text-end">$ <t t-esc="state.totals.tax.toFixed(2)"/></td>
                            </tr>
                            <tr class="border-top">
                                <td class="text-end fw-bold fs-5">Total:</td>
                                <td class="text-end fw-bold fs-5">$ <t t-esc="state.totals.total.toFixed(2)"/></td>
                            </tr>
                        </table>
                    </div>
                </div>

            </div>
        </div>
    </t>
</templates>